#!/usr/bin/env bash
# ── pre-commit hook — dynamic-hypergraph-explorer shared clone ────────
#
# PURPOSE
#   Block direct commits to 'main'.  All changes must go through a
#   topic branch (feat/<name>-<slug> or fix/<name>-<slug>), then be
#   fast-forward merged after tests pass.
#
# BACKGROUND
#   This repo uses a single shared clone at:
#     /data/projects/dynamichypergraph/repo/shared
#   Multiple agents commit concurrently.  The harness Bash tool resets
#   cwd between calls, so "what branch am I on?" is not preserved
#   across shell invocations.  Direct-to-main incidents have occurred;
#   this hook is the safety net.
#
# BYPASS (genuine emergencies only — Coach pre-authorization required)
#   1. Message Coach and get explicit approval BEFORE bypassing.
#   2. Announce on broadcast with the approval reference.
#   3. Then run: git commit --no-verify -m "..."
#   Undocumented bypasses will be flagged in the next review.
#
# INSTALLATION (already done for the shared clone)
#   git config core.hooksPath .githooks
#
# ACTIVATION CHECK
#   git config core.hooksPath   # should print ".githooks"

BRANCH=$(git branch --show-current 2>/dev/null)

# Detached HEAD (e.g. during rebase) — allow without complaint.
if [ -z "$BRANCH" ]; then
  exit 0
fi

if [ "$BRANCH" = "main" ]; then
  echo "" >&2
  echo "  ✗  BLOCKED: direct commit to 'main' is not allowed." >&2
  echo "" >&2
  echo "  All changes must go through a topic branch:" >&2
  echo "    git checkout -b feat/<your-name>-<slug>   # or fix/..." >&2
  echo "    # edit, test, then:" >&2
  echo "    git push -u origin feat/<your-name>-<slug>" >&2
  echo "    # fast-forward merge to main only after tests pass" >&2
  echo "" >&2
  echo "  Emergency bypass — Coach pre-authorization required:" >&2
  echo "    1. Get Coach approval first (message Coach, note the task/reason)." >&2
  echo "    2. Announce on broadcast with the approval reference." >&2
  echo "    3. git commit --no-verify -m \"...\"" >&2
  echo "" >&2
  exit 1
fi

exit 0
