# Ignore everything except project files
*
!.gitignore
!build_explorer.py
!extracted_data.json
!index.html
!Dockerfile
!zeabur.json

# Server
!server/
!server/__init__.py
!server/engine.py
!server/main.py
!server/requirements.txt

# Client
!client/
!client/index.html
!client/app.js

# DevX
!.dockerignore
!pytest.ini
!requirements-dev.txt
!tests/
!tests/__init__.py
!tests/test_engine.py
!tests/test_api.py

# Git hooks (tracked so all agents get the same rules)
!.githooks/
!.githooks/pre-commit

# Python cache
__pycache__/
*.pyc
