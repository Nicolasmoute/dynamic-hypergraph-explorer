# Ignore everything except project files
*
!.gitignore
!Dockerfile
!start.sh
!zeabur.json

# Server
!server/
!server/__init__.py
!server/engine.py
!server/main.py
!server/warmup.py
!server/requirements.txt

# Client
!client/
!client/index.html
!client/app.js
!client/canvas-renderer.js
!client/layout-worker.js

# Docs
!README.md

# DevX
!.dockerignore
!pytest.ini
!requirements-dev.txt
!tests/
!tests/__init__.py
!tests/test_engine.py
!tests/test_api.py
!tests/test_smoke.py
!tests/conftest.py
!tests/test_browser_smoke.py
!tests/test_dimension.py
!tests/test_layout_worker_smoke.html

# Git hooks (tracked so all agents get the same rules)
!.githooks/
!.githooks/pre-commit

# Python cache
__pycache__/
*.pyc
